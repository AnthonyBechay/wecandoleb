{
  "name": "wecandoleb",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:backend": "turbo dev --filter=@wecandoleb/backend",
    "dev:web": "turbo dev --filter=@wecandoleb/web",
    "db:push": "pnpm --filter @wecandoleb/backend db:push",
    "db:migrate": "pnpm --filter @wecandoleb/backend db:migrate",
    "db:seed": "pnpm --filter @wecandoleb/backend db:seed",
    "db:studio": "pnpm --filter @wecandoleb/backend db:studio"
  },
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  }
}