generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  USER
  BUSINESS_OWNER
  ADMIN
  SUPER_ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum ExperienceStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  PURCHASE
  GIFT_SENT
  GIFT_RECEIVED
  REDEMPTION
  REFUND
  ADMIN_ADJUSTMENT
}

enum GiftStatus {
  PENDING
  CLAIMED
  EXPIRED
  CANCELLED
}

enum DifficultyLevel {
  EASY
  MODERATE
  CHALLENGING
}

enum MeetingSource {
  PLATFORM  // booked through WeCanDoLeb
  EXTERNAL  // booked directly (phone, walk-in, another channel)
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ─── USER & AUTH ─────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  passwordHash  String?
  firstName     String
  lastName      String
  phone         String?
  avatarUrl     String?
  role          Role         @default(USER)
  authProvider  AuthProvider  @default(LOCAL)
  googleId      String?      @unique
  emailVerified Boolean      @default(false)
  isActive      Boolean      @default(true)
  creditBalance Int          @default(0) // credits in cents
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  businesses         Business[]
  bookings           Booking[]
  reviews            Review[]
  creditTransactions CreditTransaction[]
  giftsSent          Gift[]              @relation("GiftSender")
  giftsReceived      Gift[]              @relation("GiftRecipient")
  refreshTokens      RefreshToken[]
  wishlist           WishlistItem[]
  notifications      Notification[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── BUSINESS ────────────────────────────────────────────

model Business {
  id          String   @id @default(cuid())
  name        String
  description String?
  phone       String?
  email       String?
  website     String?
  logoUrl     String?
  coverUrl    String?
  address     String?
  city        String?
  region      String?
  latitude    Float?
  longitude   Float?
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  experiences     Experience[]
  meetings        ProviderMeeting[]
  experienceLinks ExperienceBusiness[]

  @@map("businesses")
}

// ─── EXPERIENCE / ACTIVITY ───────────────────────────────

model Category {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  description String?
  iconUrl     String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  experiences Experience[]

  @@map("categories")
}

model Experience {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  shortDescription String
  description      String
  highlights       String[]         // array of highlight bullet points
  includes         String[]         // what's included (itemized)
  includesNote     String?          // "what you get" — free text
  whatToBring      String[]         // what to bring (itemized checkboxes)
  whatToBringNote  String?          // extra "what to bring" — free text
  priceCredits     Int              // price in credits (cents)
  priceCurrency    Float            // price in USD for display
  costCredits      Int              @default(0) // provider's cost in credits (cents)
  costCurrency     Float            @default(0)  // provider's cost in USD
  duration         Int              // duration in minutes
  maxParticipants  Int              // max people per session
  minParticipants  Int              @default(1) // min people for a session to run
  difficulty       DifficultyLevel  @default(EASY)
  minAge           Int?
  maxAge           Int?
  address          String           // primary location address
  city             String
  region           String
  latitude         Float?
  longitude        Float?
  coverImage       String?
  status           ExperienceStatus @default(DRAFT)
  averageRating    Float            @default(0)
  totalReviews     Int              @default(0)
  totalBookings    Int              @default(0)
  featured         Boolean          @default(false)
  categoryId       String
  category         Category         @relation(fields: [categoryId], references: [id])
  businessId       String
  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  images    ExperienceImage[]
  sessions  ExperienceSession[]
  bookings  Booking[]
  reviews   Review[]
  wishlist  WishlistItem[]
  giftItems GiftItem[]
  meetings  ProviderMeeting[]
  locations ExperienceBusiness[] // businesses/venues that host this experience

  @@map("experiences")
}

// ─── EXPERIENCE ↔ BUSINESS (multi-location collaboration) ─
// An experience can be hosted by more than one business (e.g. a dancing class
// run at a Byblos venue and a Beirut venue). The owning business is added
// automatically as the primary; the owner can request other businesses to
// collaborate, and each of those must accept before it goes live.

enum CollaborationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model ExperienceBusiness {
  id           String              @id @default(cuid())
  experienceId String
  experience   Experience          @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  businessId   String
  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  status       CollaborationStatus @default(PENDING)
  isPrimary    Boolean             @default(false)
  // Location-specific venue details (defaults copied from the experience)
  address      String?
  city         String?
  region       String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  sessions ExperienceSession[]

  @@unique([experienceId, businessId])
  @@index([businessId, status])
  @@map("experience_businesses")
}

model ExperienceImage {
  id           String     @id @default(cuid())
  url          String
  alt          String?
  sortOrder    Int        @default(0)
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@map("experience_images")
}

model ExperienceSession {
  id                   String              @id @default(cuid())
  experienceId         String
  experience           Experience          @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  // Which hosting location (business) this session runs at. Nullable for
  // legacy single-location experiences; new sessions always set it.
  experienceBusinessId String?
  location             ExperienceBusiness? @relation(fields: [experienceBusinessId], references: [id], onDelete: Cascade)
  startTime            DateTime
  endTime              DateTime
  capacity             Int?                // original number of spots (for "X of Y booked")
  spotsLeft            Int
  isActive             Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  // Relations
  bookings Booking[]

  @@map("experience_sessions")
}

// ─── BOOKING ─────────────────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  experienceId  String
  experience    Experience    @relation(fields: [experienceId], references: [id])
  sessionId     String
  session       ExperienceSession @relation(fields: [sessionId], references: [id])
  participants  Int           @default(1)
  totalCredits  Int           // total credits charged
  status        BookingStatus @default(PENDING)
  specialNotes  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  payment Payment?

  @@map("bookings")
}

// ─── PAYMENT ─────────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  bookingId       String        @unique
  booking         Booking       @relation(fields: [bookingId], references: [id])
  amountCents     Int
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  paymentMethod   String?
  transactionRef  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

// ─── CREDITS & GIFTING ───────────────────────────────────

model CreditTransaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int             // positive = credit, negative = debit
  type        TransactionType
  description String?
  referenceId String?         // booking ID, gift ID, etc.
  createdAt   DateTime        @default(now())

  @@map("credit_transactions")
}

model CreditPackage {
  id          String  @id @default(cuid())
  name        String
  credits     Int     // credits in cents
  priceUsd    Float
  bonus       Int     @default(0) // bonus credits
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("credit_packages")
}

model Gift {
  id              String     @id @default(cuid())
  senderId        String
  sender          User       @relation("GiftSender", fields: [senderId], references: [id])
  recipientId     String?
  recipient       User?      @relation("GiftRecipient", fields: [recipientId], references: [id])
  recipientEmail  String
  recipientName   String
  message         String?
  totalCredits    Int        // total credits gifted
  code            String     @unique // redemption code
  status          GiftStatus @default(PENDING)
  sendEmail       Boolean    @default(false)
  giftType        String     @default("credits") // "credits" or "experience"
  claimedAt       DateTime?
  expiresAt       DateTime
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  items GiftItem[]

  @@map("gifts")
}

model GiftItem {
  id           String     @id @default(cuid())
  giftId       String
  gift         Gift       @relation(fields: [giftId], references: [id], onDelete: Cascade)
  experienceId String?
  experience   Experience? @relation(fields: [experienceId], references: [id])
  credits      Int        // credits allocated to this item
  tickets      Int        @default(1) // number of tickets/participants
  createdAt    DateTime   @default(now())

  @@map("gift_items")
}

// ─── REVIEWS ─────────────────────────────────────────────

model Review {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  rating       Int        // 1-5
  comment      String?
  isPublished  Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, experienceId])
  @@map("reviews")
}

// ─── WISHLIST ────────────────────────────────────────────

model WishlistItem {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, experienceId])
  @@map("wishlist_items")
}

// ─── NOTIFICATIONS ───────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // booking_confirmed, gift_received, etc.
  isRead    Boolean  @default(false)
  data      Json?    // extra metadata
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ─── BUSINESS REGISTRATION ───────────────────────────────

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

model BusinessRegistration {
  id            String             @id @default(cuid())
  businessName  String
  description   String?
  ownerName     String
  ownerEmail    String
  ownerPhone    String?
  city          String?
  region        String?
  address       String?
  website       String?
  message       String?            // why they want to join
  status        RegistrationStatus @default(PENDING)
  reviewedBy    String?            // admin who reviewed
  reviewNote    String?
  userId        String?            // linked user if they have an account
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@map("business_registrations")
}

// ─── PROVIDER MEETINGS / SCHEDULE ────────────────────────
// Meetings an artisan / experience provider organizes. Includes bookings
// made directly (outside the platform) so they can see their whole schedule
// in one place. Platform bookings are derived from ExperienceSession/Booking.

model ProviderMeeting {
  id            String        @id @default(cuid())
  businessId    String
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  experienceId  String?
  experience    Experience?   @relation(fields: [experienceId], references: [id], onDelete: SetNull)
  title         String
  startTime     DateTime
  endTime       DateTime?
  headcount     Int           @default(1)
  location      String?
  customerName  String?
  customerPhone String?
  notes         String?
  source        MeetingSource @default(EXTERNAL)
  status        MeetingStatus @default(SCHEDULED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([businessId, startTime])
  @@map("provider_meetings")
}

// ─── AUDIT LOG ───────────────────────────────────────────
// Immutable record of significant actions across the platform. No FK to the
// user so entries survive account deletion (actor snapshot is stored inline).

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  actorRole  String?
  category   String   // AUTH | CREDIT | GIFT | BOOKING | EXPERIENCE | BUSINESS | USER | REGISTRATION | ADMIN
  action     String   // e.g. CREDIT_PURCHASE, GIFT_CLAIM, USER_ROLE_CHANGE
  summary    String   // human-readable one-liner
  targetType String?  // e.g. User, Business, Experience, Gift, Booking
  targetId   String?
  amount     Int?     // credits involved (cents), where relevant
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([category, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── SITE SETTINGS ───────────────────────────────────────

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("site_settings")
}
